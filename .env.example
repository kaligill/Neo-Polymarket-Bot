# ---- Runtime mode ----
ENV=development
PAPER_TRADING=true

# ---- Polymarket ----
# Read-only market data does not require credentials. These are only needed
# once you implement LiveExecutionClient (strategy/execution.py) for real trading.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_WALLET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://neo:neo@localhost:5432/neo_polymarket
REDIS_URL=redis://localhost:6379/0

# ---- LLM ----
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- News / Social ----
NEWSAPI_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=neo-polymarket-bot/0.1

# ---- Risk thresholds (see config.py for full list + defaults) ----
MIN_EDGE_THRESHOLD=0.07
MIN_CONFIDENCE_THRESHOLD=0.65
MAX_DAILY_LOSS_PCT=0.05
STARTING_BANKROLL_USD=10000
